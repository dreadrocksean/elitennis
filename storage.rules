rules_version = '2';

// Gallery images: public read (shown on the site), owner-only write.
// Keep the owner list in sync with firestore.rules and VITE_OWNER_EMAIL.
service firebase.storage {
  match /b/{bucket}/o {
    function isOwner() {
      return request.auth != null
        && request.auth.token.email.lower() in [
             'elijahdona77@gmail.com',
             'adrianbartholomew25@pm.me'
           ];
    }

    match /gallery/{fileName} {
      allow read: if true;
      allow write: if isOwner()
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
